<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
    <Label text="Stylized Nested Layout Example" style="-fx-font-size: 16px; -fx-text-fill: darkblue;" />

    <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #EFEFEF; -fx-padding: 10;">
        <Button text="Button 1" style="-fx-background-color: #DDEEFF; -fx-text-fill: #333;" />
        <Button text="Button 2" style="-fx-background-color: #FFDDEE; -fx-text-fill: #333;" />
        <Button text="Button 3" style="-fx-background-color: #EEFFDD; -fx-text-fill: #333;" />
    </HBox>

    <GridPane hgap="10" vgap="10" style="-fx-border-color: darkgray; -fx-border-width: 2px;">
        <Label text="Row 0, Col 0" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label text="Row 0, Col 1" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Row 1, Col 0" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label text="Row 1, Col 1" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>
</VBox>

