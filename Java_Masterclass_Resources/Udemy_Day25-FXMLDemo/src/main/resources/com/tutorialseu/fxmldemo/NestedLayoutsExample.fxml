<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
    <Label text="Nested Layout Example" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Button 1" />
        <Button text="Button 2" />
        <Button text="Button 3" />
    </HBox>

    <GridPane hgap="10" vgap="10">
        <Label text="Row 0, Col 0" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label text="Row 0, Col 1" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Row 1, Col 0" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label text="Row 1, Col 1" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>
</VBox>

